font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true

theme = Gruvbox Material Dark

# Selection colors (override theme defaults for better visibility)
selection-background = #689d6a
selection-foreground = #1d2021

window-padding-x = 8
window-padding-y = 4
window-decoration = true
background-opacity = 0.95

cursor-style = block
cursor-style-blink = true

command = /usr/bin/zsh
shell-integration = zsh

{{ if eq .chezmoi.os "darwin" -}}
# macOS: Cmd (super) based keybinds
keybind = super+shift+t=new_tab
keybind = super+shift+w=close_surface
keybind = super+shift+enter=new_split:right
keybind = super+shift+o=new_split:down
keybind = super+shift+h=goto_split:left
keybind = super+shift+l=goto_split:right
keybind = super+shift+k=goto_split:top
keybind = super+shift+j=goto_split:bottom
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size
{{ else -}}
# Linux: Ctrl based keybinds
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+enter=new_split:right
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
{{ end -}}
