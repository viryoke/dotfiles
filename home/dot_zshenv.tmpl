# ~/.zshenv - Managed by chezmoi
# Sourced by ALL zsh invocations (interactive, scripts, cron).
# Only variables that non-shell processes need belong here.

# === XDG Base Directories ===
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# === Locale ===
export LANG=en_US.UTF-8
{{ if eq .chezmoi.os "darwin" }}
export LC_ALL=en_US.UTF-8
{{ end }}

# === PATH bootstrap ===
export PATH="$HOME/.nix-profile/bin:$HOME/.local/bin:$PATH"
{{ if eq .chezmoi.os "darwin" }}
export PATH="/opt/homebrew/bin:$PATH"
{{ end }}

{{ if eq .chezmoi.os "linux" }}
# === Flatpak (GUI apps need these) ===
export XDG_DATA_DIRS="/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share:${XDG_DATA_DIRS:-}"
export XDG_DATA_DIRS="/usr/local/share:/usr/share:$XDG_DATA_DIRS"

# === Fcitx5 Input Method (GTK/Qt apps read these) ===
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export SDL_IM_MODULE=fcitx
export INPUT_METHOD=fcitx
{{ end }}

# === npm (may be called from scripts) ===
export npm_config_prefix="$HOME/.npm-global"
export PATH="$HOME/.npm-global/bin:$PATH"

{{ if eq .chezmoi.os "darwin" }}
# === Homebrew ===
export HOMEBREW_NO_AUTO_UPDATE=1
{{ end }}

# === TERM fallback ===
if [ -n "$TERM" ] && ! infocmp "$TERM" &>/dev/null 2>&1; then
  export TERM=xterm-256color
fi
