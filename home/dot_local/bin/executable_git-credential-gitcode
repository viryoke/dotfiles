#!/bin/bash
if [ "$(uname)" = "Darwin" ]; then
  TOKEN_FILE="$(getconf DARWIN_USER_TEMP_DIR)/agenix/gitcode_token"
else
  TOKEN_FILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/agenix/gitcode_token"
fi
if [ -f "$TOKEN_FILE" ]; then
  echo "protocol=https"
  echo "host=gitcode.com"
  echo "username=viryoke"
  echo "password=$(cat "$TOKEN_FILE")"
fi
