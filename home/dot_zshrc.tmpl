# ~/.zshrc - Managed by chezmoi
# Fish is the primary shell. Zsh only serves as a fallback launcher.

# === Nix environment ===
if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
  . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi

# === Launch fish if available ===
if command -v fish &>/dev/null; then
  exec fish
fi

# === Minimal zsh fallback (only if fish is unavailable) ===
export EDITOR=nvim
export VISUAL=nvim
alias ll='eza -la --icons --git'
alias lg='lazygit'
alias v='nvim'
eval "$(starship init zsh 2>/dev/null)"
