#!/bin/bash
set -euo pipefail

echo "=== Deploying Nix home-manager ==="

DOTFILES_DIR="{{ .chezmoi.workingTree }}"
USERNAME="{{ .username }}"
HOSTNAME="{{ .hostname }}"

if command -v nix &>/dev/null; then
  cd "$DOTFILES_DIR"
  echo "Running home-manager switch for ${USERNAME}@${HOSTNAME}..."
  nix run home-manager -- switch --flake ".#${USERNAME}@${HOSTNAME}" --impure
  echo "=== home-manager deployment complete ==="
else
  echo "WARNING: Nix not found. Skipping home-manager deployment."
  echo "Install Nix first: sh <(curl -L https://nixos.org/nix/install) --no-daemon"
fi
