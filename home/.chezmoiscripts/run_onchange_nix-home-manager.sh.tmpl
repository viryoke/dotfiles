#!/bin/bash
set -euo pipefail

echo "=== Deploying Nix home-manager ==="

DOTFILES_DIR="{{ .chezmoi.workingTree }}"
# Normalize hostname to match flake.nix homeConfigurations keys
{{ if or (eq .chezmoi.hostname "macbook") (contains "MacBook" .chezmoi.hostname) }}
HOSTNAME="macbook"
{{ else }}
HOSTNAME="{{ .chezmoi.hostname }}"
{{ end }}

if command -v nix &>/dev/null; then
  cd "$DOTFILES_DIR"
  echo "Running home-manager switch for viryoke@${HOSTNAME}..."
  nix run home-manager -- switch --flake ".#viryoke@${HOSTNAME}" --impure
  echo "=== home-manager deployment complete ==="
else
  echo "WARNING: Nix not found. Skipping home-manager deployment."
  echo "Install Nix first: sh <(curl -L https://nixos.org/nix/install) --daemon"
fi
