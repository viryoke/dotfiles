#!/bin/bash

{{ if eq .chezmoi.os "linux" -}}
echo "=== Installing Linux packages ==="

if command -v pacman &>/dev/null; then
  echo "Installing pacman packages..."
  # --ignore: skip nvidia packages (CachyOS handles GPU drivers)
  sudo pacman -S --needed --noconfirm \
    --ignore nvidia-open-dkms,nvidia-dkms,nvidia,nvidia-open \
    {{ range .packages.linux.pacman }}{{ . | quote }} {{ end }} || true

  {{ if eq .chezmoi.arch "amd64" }}
  {{ if .packages.linux.pacman_amd64 }}
  echo "Installing amd64-specific pacman packages..."
  sudo pacman -S --needed --noconfirm \
    --ignore nvidia-open-dkms,nvidia-dkms,nvidia,nvidia-open \
    {{ range .packages.linux.pacman_amd64 }}{{ . | quote }} {{ end }} || true
  {{ end }}
  {{ end }}
fi

{{ if .packages.linux.aur }}
if command -v yay &>/dev/null; then
  echo "Installing AUR packages via yay..."
  {{ range .packages.linux.aur -}}
  yay -S --needed --noconfirm {{ . | quote }} || true
  {{ end }}
elif command -v paru &>/dev/null; then
  echo "Installing AUR packages via paru..."
  {{ range .packages.linux.aur -}}
  paru -S --needed --noconfirm {{ . | quote }} || true
  {{ end }}
else
  echo "WARNING: No AUR helper found (yay/paru). Skipping AUR packages."
fi
{{ end }}

if command -v flatpak &>/dev/null; then
  echo "Setting up Flatpak..."
  flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

  {{ range .packages.linux.flatpak -}}
  echo "Installing {{ . }}..."
  flatpak install --user -y flathub {{ . | quote }} || true
  {{ end }}
fi

echo "=== Linux packages installation complete ==="

exit 0
{{ end -}}
