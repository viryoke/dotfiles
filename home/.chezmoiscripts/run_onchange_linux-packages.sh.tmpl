#!/bin/bash

{{ if eq .chezmoi.os "linux" -}}
echo "=== Installing Linux packages ==="

if command -v pacman &>/dev/null; then
  echo "Installing pacman packages one by one..."
  {{ range .packages.linux.pacman -}}
  echo "  → {{ . }}"
  sudo pacman -S --needed --noconfirm "{{ . }}" 2>/dev/null || echo "  ⚠ skipped: {{ . }}"
  {{ end }}

  {{ if eq .chezmoi.arch "amd64" }}
  {{ if .packages.linux.pacman_amd64 }}
  echo "Installing amd64-specific packages..."
  {{ range .packages.linux.pacman_amd64 -}}
  echo "  → {{ . }}"
  sudo pacman -S --needed --noconfirm "{{ . }}" 2>/dev/null || echo "  ⚠ skipped: {{ . }}"
  {{ end }}
  {{ end }}
  {{ end }}
fi

{{ if .packages.linux.aur }}
if command -v yay &>/dev/null; then
  echo "Installing AUR packages..."
  {{ range .packages.linux.aur -}}
  echo "  → {{ . }}"
  yay -S --needed --noconfirm "{{ . }}" || echo "  ⚠ skipped: {{ . }}"
  {{ end }}
elif command -v paru &>/dev/null; then
  echo "Installing AUR packages..."
  {{ range .packages.linux.aur -}}
  echo "  → {{ . }}"
  paru -S --needed --noconfirm "{{ . }}" || echo "  ⚠ skipped: {{ . }}"
  {{ end }}
else
  echo "WARNING: No AUR helper found (yay/paru). Skipping AUR packages."
fi
{{ end }}

if command -v flatpak &>/dev/null; then
  echo "Setting up Flatpak..."
  flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

  {{ range .packages.linux.flatpak -}}
  echo "  → {{ . }}"
  flatpak install --user -y flathub {{ . | quote }} || echo "  ⚠ skipped: {{ . }}"
  {{ end }}
fi

echo "=== Linux packages installation complete ==="
{{ end -}}
