#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "linux" -}}
# Auto-build Rime schemas after chezmoi apply
# Runs when rime-ice external or default.yaml changes

RIME_BUILD="$HOME/.local/bin/rime-build.sh"

if [ -x "$RIME_BUILD" ]; then
    "$RIME_BUILD" || echo "WARNING: Rime build failed — run manually: rime-build.sh"
fi
{{ end -}}
