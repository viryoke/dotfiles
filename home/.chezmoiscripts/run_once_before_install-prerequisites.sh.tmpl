#!/bin/bash
set -euo pipefail

echo "=== Phase 0: Environment Pre-check ==="
echo "OS: {{ .chezmoi.os }}"
echo "Arch: {{ .chezmoi.arch }}"
{{ if eq .chezmoi.os "linux" }}
echo "Distro: {{ .chezmoi.osRelease.id }}"
{{ end }}
echo "Hostname: {{ .chezmoi.hostname }}"

{{ if eq .chezmoi.os "linux" }}
# Generate locales
if command -v locale-gen &>/dev/null || [ -f /etc/locale.gen ]; then
  echo "Generating locales..."
  grep -q "en_US.UTF-8" /etc/locale.gen 2>/dev/null || echo "en_US.UTF-8 UTF-8" | sudo tee -a /etc/locale.gen 2>/dev/null || true
  grep -q "zh_CN.UTF-8" /etc/locale.gen 2>/dev/null || echo "zh_CN.UTF-8 UTF-8" | sudo tee -a /etc/locale.gen 2>/dev/null || true
  sudo locale-gen 2>/dev/null || true
  echo "LANG=en_US.UTF-8" | sudo tee /etc/locale.conf > /dev/null 2>/dev/null || true
fi

# Add zsh to /etc/shells
if command -v zsh &>/dev/null; then
  ZSH_PATH="$(which zsh)"
  if ! grep -q "$ZSH_PATH" /etc/shells 2>/dev/null; then
    echo "$ZSH_PATH" | sudo tee -a /etc/shells > /dev/null 2>/dev/null || true
  fi
fi

if ! command -v nix &>/dev/null; then
  echo "Installing Nix (single-user)..."
  sh <(curl -L https://nixos.org/nix/install) --no-daemon
  . /etc/profile.d/nix.sh 2>/dev/null || . "$HOME/.nix-profile/etc/profile.d/nix.sh" 2>/dev/null || true
fi

# Configure Nix binary cache mirrors (China)
mkdir -p "$HOME/.config/nix"
cat > "$HOME/.config/nix/nix.conf" << 'EOF'
experimental-features = nix-command flakes
substituters = https://mirrors.tuna.tsinghua.edu.cn/nix-channels/store https://mirror.sjtu.edu.cn/nix-channels/store https://cache.nixos.org
trusted-public-keys = cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY=
EOF
echo "  Nix mirrors configured (TUNA/SJTU)"

# Configure system-level /etc/nix/nix.conf (daemon level — always respected)
# Uses sed to replace existing lines so wrong values get corrected.
# NOTE: sudo may fail with exit 2 when stdin is not a terminal (chezmoi apply).
#       Each sudo call is guarded so set -e never kills the script on sudo failure.
NIX_SUBSTITUTERS="https://mirrors.tuna.tsinghua.edu.cn/nix-channels/store https://mirror.sjtu.edu.cn/nix-channels/store https://cache.nixos.org"
NIX_TRUSTED_KEYS="cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY="

# Run a sudo command; on failure (e.g. no tty), log and continue instead of crashing.
try_sudo() { if "$@" 2>/dev/null; then return 0; else echo "  ⚠ sudo failed (credentials not cached?) — skipping"; return 1; fi; }

if [ ! -f /etc/nix/nix.conf ]; then
  try_sudo mkdir -p /etc/nix
  try_sudo tee /etc/nix/nix.conf > /dev/null << SYSCONF
trusted-users = root $USER
substituters = ${NIX_SUBSTITUTERS}
trusted-public-keys = ${NIX_TRUSTED_KEYS}
SYSCONF
  echo "  /etc/nix/nix.conf created"
else
  if ! grep -q "trusted-users.*$USER" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo bash -c "echo 'trusted-users = root $USER' >> /etc/nix/nix.conf"; then
      echo "  trusted-users configured"
    fi
  fi
  if grep -q "^substituters" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo sed -i "s|^substituters.*|substituters = ${NIX_SUBSTITUTERS}|" /etc/nix/nix.conf; then
      echo "  substituters updated"
    fi
  else
    if try_sudo bash -c "echo 'substituters = ${NIX_SUBSTITUTERS}' >> /etc/nix/nix.conf"; then
      echo "  substituters configured"
    fi
  fi
  if grep -q "^trusted-public-keys" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo sed -i "s|^trusted-public-keys.*|trusted-public-keys = ${NIX_TRUSTED_KEYS}|" /etc/nix/nix.conf; then
      echo "  trusted-public-keys updated"
    fi
  else
    if try_sudo bash -c "echo 'trusted-public-keys = ${NIX_TRUSTED_KEYS}' >> /etc/nix/nix.conf"; then
      echo "  trusted-public-keys configured"
    fi
  fi
fi
{{ else if eq .chezmoi.os "darwin" }}
if ! xcode-select -p &>/dev/null; then
  echo "Installing Xcode CLI tools..."
  xcode-select --install
  echo "Please complete Xcode CLI tools installation and re-run."
  exit 1
fi

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if ! command -v nix &>/dev/null; then
  echo "Installing Nix (single-user)..."
  sh <(curl -L https://nixos.org/nix/install) --no-daemon
  . "$HOME/.nix-profile/etc/profile.d/nix.sh" 2>/dev/null || true
fi

# Configure Nix binary cache mirrors (China)
mkdir -p "$HOME/.config/nix"
cat > "$HOME/.config/nix/nix.conf" << 'EOF'
experimental-features = nix-command flakes
substituters = https://mirrors.tuna.tsinghua.edu.cn/nix-channels/store https://mirror.sjtu.edu.cn/nix-channels/store https://cache.nixos.org
trusted-public-keys = cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY=
EOF
echo "  Nix mirrors configured (TUNA/SJTU)"

# Configure system-level /etc/nix/nix.conf (daemon level — always respected)
# NOTE: sudo may fail with exit 2 when stdin is not a terminal (chezmoi apply).
#       Each sudo call is guarded so set -e never kills the script on sudo failure.
NIX_SUBSTITUTERS="https://mirrors.tuna.tsinghua.edu.cn/nix-channels/store https://mirror.sjtu.edu.cn/nix-channels/store https://cache.nixos.org"
NIX_TRUSTED_KEYS="cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY="

try_sudo() { if "$@" 2>/dev/null; then return 0; else echo "  ⚠ sudo failed — skipping"; return 1; fi; }

if [ ! -f /etc/nix/nix.conf ]; then
  try_sudo mkdir -p /etc/nix
  try_sudo tee /etc/nix/nix.conf > /dev/null << SYSCONF
trusted-users = root $USER
substituters = ${NIX_SUBSTITUTERS}
trusted-public-keys = ${NIX_TRUSTED_KEYS}
SYSCONF
  echo "  /etc/nix/nix.conf created"
else
  if ! grep -q "trusted-users.*$USER" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo bash -c "echo 'trusted-users = root $USER' >> /etc/nix/nix.conf"; then
      echo "  trusted-users configured"
    fi
  fi
  if grep -q "^substituters" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo sed -i '' "s|^substituters.*|substituters = ${NIX_SUBSTITUTERS}|" /etc/nix/nix.conf; then
      echo "  substituters updated"
    fi
  else
    if try_sudo bash -c "echo 'substituters = ${NIX_SUBSTITUTERS}' >> /etc/nix/nix.conf"; then
      echo "  substituters configured"
    fi
  fi
  if grep -q "^trusted-public-keys" /etc/nix/nix.conf 2>/dev/null; then
    if try_sudo sed -i '' "s|^trusted-public-keys.*|trusted-public-keys = ${NIX_TRUSTED_KEYS}|" /etc/nix/nix.conf; then
      echo "  trusted-public-keys updated"
    fi
  else
    if try_sudo bash -c "echo 'trusted-public-keys = ${NIX_TRUSTED_KEYS}' >> /etc/nix/nix.conf"; then
      echo "  trusted-public-keys configured"
    fi
  fi
fi
{{ end }}

echo "=== Prerequisites check complete ==="
